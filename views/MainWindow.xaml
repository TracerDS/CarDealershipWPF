<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="AutoKomis.MainWindow"
        Title="AutoKomis Manager - Katalog Pojazdów" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F4F6F9">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" d:IsLocked="True">
            <StackPanel x:Name="LeftPanel" Margin="15">
                <TextBlock x:Name="SearchText" Text="Wyszukiwarka" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333"/>

                <TextBlock x:Name="ModelText" Text="Marka:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="ModelComboBox" Margin="0,0,0,15" SelectedIndex="0" SelectionChanged="ModelComboBox_Change">
                    <ComboBoxItem Content="Wszystkie"/>
                    <ComboBoxItem Content="Audi"/>
                    <ComboBoxItem Content="BMW"/>
                    <ComboBoxItem Content="Toyota"/>
                    <ComboBoxItem Content="Volvo"/>
                </ComboBox>

                <TextBlock x:Name="MaxPriceText" Text="Cena maksymalna (PLN):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <Slider Minimum="10000" Maximum="500000" TickFrequency="10000" IsSnapToTickEnabled="True" Margin="0,0,0,5" x:Name="MaxPriceSlider" Background="White" Value="500000" ValueChanged="MaxPriceSlider_ValueChanged"/>
                <TextBlock x:Name="MaxPriceLabelText" Text="{Binding Value, ElementName=MaxPriceSlider}" HorizontalAlignment="Right" Margin="0,0,0,15"/>

                <TextBlock x:Name="FuelTypeText" Text="Rodzaj paliwa:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="FuelTypeComboBox" Margin="0,0,0,25" SelectedIndex="0" SelectionChanged="FuelTypeComboBox_SelectionChanged">
                    <ComboBoxItem Content="Wszystkie"/>
                    <ComboBoxItem Content="Benzyna"/>
                    <ComboBoxItem Content="Diesel"/>
                    <ComboBoxItem Content="Hybryda"/>
                    <ComboBoxItem Content="Elektryczny"/>
                </ComboBox>

                <Button x:Name="SearchBtn" Content="Szukaj / Odśwież" Background="#007BFF" Foreground="White" FontWeight="Bold" Padding="10" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="15,0" d:IsLocked="True">
                <Button x:Name="AddCarBtn" Content="+ Dodaj pojazd" Background="#28A745" Foreground="White" Padding="15,8" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand" Click="AddCarBtn_Click"/>
                <Button x:Name="SaveDatabaseBtn" Content="Zapisz bazę" Background="#6C757D" Foreground="White" Padding="15,8" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand" Click="SaveDatabaseBtn_Click"/>
                <Button x:Name="SettingsBtn" Content="Ustawienia" Background="#17A2B8" Foreground="White" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>

            <TextBlock x:Name="AvailableCarsText" Text="Dostępne pojazdy w komisie" FontSize="22" FontWeight="Light" VerticalAlignment="Center" Margin="20,0,354,0"/>

            <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="15" x:Name="MainWindowBox" ScrollViewer.HorizontalScrollBarVisibility="Disabled" d:IsLocked="True">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Background="White" Margin="10" CornerRadius="8" Padding="10">
                            <Border.Effect>
                                <DropShadowEffect Color="Gray" Direction="270" ShadowDepth="2" Opacity="0.2" BlurRadius="5"/>
                            </Border.Effect>
                            <StackPanel>
                                <Border Height="120" Background="#E9ECEF" CornerRadius="5" Margin="0,0,0,10">
                                    <TextBlock Text="[ ZDJĘCIE ]" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#ADB5BD"/>
                                </Border>
                                <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Details}" Foreground="#6C757D" FontSize="12" Margin="0,5,0,10"/>
                                <TextBlock Text="{Binding PriceText}" FontWeight="Bold" FontSize="18" Foreground="#28A745" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>